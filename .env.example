# --- Base de datos (compartida por backend y bot) ---
DATABASE_URL=postgresql://usuario:password@localhost:5432/inventario

# --- Backend (API + app web) ---
PORT=3000

# Login de la web: generá el hash con `node backend/scripts/hash-password.js "tu-contraseña"`
APP_PASSWORD_HASH=
# Cualquier cadena larga y aleatoria — usala para firmar las sesiones. No la compartas.
JWT_SECRET=

# --- Bot de Discord ---
DISCORD_TOKEN=tu_token_del_bot
DISCORD_CLIENT_ID=id_de_la_aplicacion
DISCORD_GUILD_ID=id_del_servidor_donde_se_registran_los_comandos
